{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CardioFlow.Api": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "cardioflow-api-consumer",
    "TelemetryTopic": "ecg.telemetry"
  },
  "TelemetryBuffer": {
    "MaxBufferSize": 1000
  },
  "Alerts": {
    "MaxBufferSize": 100
  },
  "Telemetry": {
    "SamplingRate": 360
  }
}