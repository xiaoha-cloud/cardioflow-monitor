{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CardioFlow.Api": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://your-swa-domain.azurestaticapps.net"
    ]
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "cardioflow-api-consumer",
    "TelemetryTopic": "ecg.telemetry"
  },
  "TelemetryBuffer": {
    "MaxBufferSize": 1000
  },
  "Alerts": {
    "MaxBufferSize": 100
  },
  "DetectionRules": {
    "HrHighThreshold": 120,
    "HrLowThreshold": 45,
    "RrLowMs": 400,
    "RrHighMs": 1200,
    "EnableRrRule": true
  },
  "Telemetry": {
    "SamplingRate": 360
  }
}