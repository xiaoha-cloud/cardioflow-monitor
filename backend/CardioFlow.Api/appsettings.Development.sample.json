{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "CardioFlow.Api": "Debug"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "Alerts": {
    "MaxBufferSize": 100
  },
  "DetectionRules": {
    "HrHighThreshold": 120,
    "HrLowThreshold": 45,
    "RrLowMs": 400,
    "RrHighMs": 1200,
    "EnableRrRule": true
  },
  "Telemetry": {
    "SamplingRate": 360
  },
  "Explainer": {
    "BaseUrl": "http://localhost:8000"
  }
}
